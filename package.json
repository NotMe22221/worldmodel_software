{
  "name": "worldmodel-for-software",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3100",
    "build": "next build --webpack",
    "build:vercel": "node scripts/check-vercel-env.mjs && next build --webpack",
    "build:local": "next build --webpack",
    "start": "next start",
    "test": "npm run build:local && npm run test:unit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "test:unit": "node --test tests/auth.test.mjs tests/bounded-mutation-routes.test.mjs tests/composio.test.mjs tests/github-publish.test.mjs tests/product-contracts.test.mjs tests/vercel-runtime.test.mjs tests/workspace-onboarding.test.mjs tests/worldmodel-engine.test.mjs tests/virtual-environment.test.mjs sample-app/tests/*.spec.mjs",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.14",
    "ws": "8.21.0"
  },
  "type": "module"
}
