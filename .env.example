# Primary GitHub OAuth: create a Composio-managed GitHub auth config once.
# Customers then connect through Composio Connect Link; they never enter keys.
# Scope the project key to the connected-account APIs, GitHub tools, and
# proxy_execute (required for exact-commit archives and approved draft PRs).
COMPOSIO_API_KEY=
COMPOSIO_GITHUB_AUTH_CONFIG_ID=
# Defaults to https://backend.composio.dev/api/v3.1. Override only for a
# local deterministic contract fixture with COMPOSIO_FIXTURE_MODE=true.
COMPOSIO_API_BASE_URL=
COMPOSIO_FIXTURE_MODE=false
# Optional canonical HTTPS override. Keep Vercel's Automatically expose System
# Environment Variables setting enabled so its deployment URL is used by default.
WORLDMODEL_PUBLIC_ORIGIN=

# Required only when deploying the Next.js application to Vercel. Install Turso
# from the Vercel Marketplace so these values are provisioned automatically.
# They are server-only and must never use NEXT_PUBLIC_ names.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional advanced fallback GitHub App: configure the setup URL as /api/integrations/github/setup
# and callback URL as /api/integrations/github/callback on the deployed origin.
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe Billing: register /api/billing/webhook and subscribe to Checkout
# Session plus customer.subscription lifecycle events.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Production operator access requires both the email and immutable auth user ID
# to match. Empty means no access; IDs use the usr_<32 hex> format.
WORLDMODEL_OPERATOR_EMAILS=
WORLDMODEL_OPERATOR_USER_IDS=
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5.6
# Opt in only after your retention policy covers provider-side response state.
OPENAI_STORE_RESPONSES=false
ARTIFACT_RETENTION_DAYS=30
# Required only for the customer-controlled GitHub Actions evidence workflow.
# Generate at least 32 random bytes; for example: openssl rand -hex 32
RUNNER_TOKEN_SECRET=
