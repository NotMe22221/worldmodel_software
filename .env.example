# GitHub App: configure the app setup URL as /api/integrations/github/setup
# and callback URL as /api/integrations/github/callback on the deployed origin.
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe Billing: register /api/billing/webhook and subscribe to Checkout
# Session plus customer.subscription lifecycle events.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Explicit comma-separated internal operator identities. Empty means no access.
WORLDMODEL_OPERATOR_EMAILS=
