# Primary GitHub OAuth: create a Composio-managed GitHub auth config once.
# Customers then connect through Composio Connect Link; they never enter keys.
# Scope the project key to the connected-account APIs, GitHub tools, and
# proxy_execute (required for exact-commit archives and approved draft PRs).
COMPOSIO_API_KEY=
COMPOSIO_GITHUB_AUTH_CONFIG_ID=
# Defaults to https://backend.composio.dev/api/v3.1. Override only for a
# local deterministic contract fixture with COMPOSIO_FIXTURE_MODE=true.
COMPOSIO_API_BASE_URL=
COMPOSIO_FIXTURE_MODE=false
WORLDMODEL_PUBLIC_ORIGIN=

# Required only when deploying the Next.js application to Vercel. Create a
# least-privilege Cloudflare API token with D1 Read and D1 Write access to this
# database. These values are server-only and must never use NEXT_PUBLIC_ names.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_API_TOKEN=

# Optional advanced fallback GitHub App: configure the setup URL as /api/integrations/github/setup
# and callback URL as /api/integrations/github/callback on the deployed origin.
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe Billing: register /api/billing/webhook and subscribe to Checkout
# Session plus customer.subscription lifecycle events.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Explicit comma-separated internal operator identities. Empty means no access.
WORLDMODEL_OPERATOR_EMAILS=
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5.6
SANDBOX_BRIDGE_URL=
SANDBOX_API_KEY=
ARTIFACT_RETENTION_DAYS=30
RUNNER_EVIDENCE_SECRET=
RUNNER_TOKEN_SECRET=
